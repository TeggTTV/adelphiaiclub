DATABASE_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Session and signing secrets
SESSION_SIGNING_SECRET=change-me-long-random-string
SESSION_TTL_HOURS=336
DASHBOARD_ACCESS_MINUTES=45

# Admin access
ADMIN_EMAILS=
# Preferred: use hashed passkey; generate with a script that uses lib/security.ts hashPassword
ADMIN_DASHBOARD_KEY_HASH=
# Optional fallback for local development only
ADMIN_DASHBOARD_KEY=

# Field-level encryption (base64 32-byte key recommended)
DATA_ENCRYPTION_KEY=

# Password reset
PASSWORD_RESET_TTL_MINUTES=30
RESEND_API_KEY=
